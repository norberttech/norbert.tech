{% extends 'base.html.twig' %}

{% block title %}{% endblock %}
{% block description %}{% endblock %}

{%- block og_img -%}
    {{ asset('images/avatar.jpeg') }}
{%- endblock -%}

{%- block og_img_type -%}
    image/jpeg
{%- endblock -%}

{%- block og_img_alt -%}
    'Norbert Orzechowicz - Personal Website
{%- endblock -%}

{% block content %}
<div class="grid grid-cols-1 sm:grid-cols-3 sm:gap-4 mx-auto max-w-screen-2xl">
    <div class="col-span-2 py-2">
        <h2 class="font-bold text-4xl mb-4">My name is Norbert</h2>
        <p class="mb-2">
            I'm a software architect with a focus on designing and building highly scalable web applications and data processing systems.
        </p>
        <p class="mb-2">
            In my spare time, I maintain several open-source projects and enjoy automating and optimizing everything around me.
        </p>

        {% if latestPost %}
        <div class="mt-6 pt-4 border-t border-gray-300">
            <h3 class="font-bold text-xl mb-2">Latest Blog Post</h3>
            <h4 class="font-semibold text-lg mb-2">
                <a href="{{ path('blog_post', {date: latestPost.date | date('Y-m-d'), slug: latestPost.slug}) }}" class="text-blue-600 hover:text-blue-800">
                    {{ latestPost.title }}
                </a>
            </h4>
            <p class="mb-2 text-gray-700">
                {{ latestPost.description }}
            </p>
            <a href="{{ path('blog_post', {date: latestPost.date | date('Y-m-d'), slug: latestPost.slug}) }}" class="text-blue-600 hover:text-blue-800 font-medium">
                Read more →
            </a>
        </div>
        {% endif %}

        <div class="mt-6">
            {{ render(controller('NorbertTech\\Portfolio\\Controller\\ProjectsController::list')) }}
        </div>
    </div>
    <div class="md:pr-4 p-2">
        <h2 class="text-lg font-bold">Links</h2>
        <ul class="lg:list-disc lg:pl-6">
            <li>
                <a href="https://twitter.com/norbert_tech" target="_blank">
                    <img src="{{ asset('images/icons/brand/x.svg') }}" alt="Twitter" class="inline w-[18px] h-[18px]"> norbert_tech
                </a>
            </li>
            <li>
                <a href="https://github.com/norberttech" target="_blank">
                    <img src="{{ asset('images/icons/brand/github.svg') }}" alt="GitHub" class="inline w-[18px] h-[18px]"> norberttech
                </a>
            </li>
            <li>
                <a href="https://www.linkedin.com/in/norberttech/" target="_blank">
                    <img src="{{ asset('images/icons/brand/linkedin.svg') }}" alt="LinkedIn" class="inline w-[18px] h-[18px]"> norberttech
                </a>
            </li>
            <li>
                <a href="mailto:contact@norbert.tech">
                    <img src="{{ asset('images/icons/mail.svg') }}" alt="Email" class="inline w-[18px] h-[18px]"> contact@norbert.tech
                </a>
            </li>
            <li>
                <a href="https://translate.google.com/translate?hl=en&sl=pl&tl=en&u=http%3A%2F%2Fzawarstwaabstrakcji.pl">
                    <img src="{{ asset('images/icons/www.svg') }}" alt="Blog" class="inline w-[18px] h-[18px]"> https://zawarstwaabstrakcji.pl
                </a>
            </li>
            <li>
                <a href="https://speakerdeck.com/norbert_tech" target="_blank">
                    <img src="{{ asset('images/icons/speakerdeck.svg') }}" alt="SpeakerDeck" class="inline w-[18px] h-[18px]"> Slides from recent talks
                </a>
            </li>
        </ul>

        <div class="mt-4">
            <a href="https://github.com/sponsors/norberttech" target="_blank" class="block rounded-xl p-5 no-underline text-white" style="background: #0d1117;">
                <div class="flex items-start gap-4">
                    <img src="{{ asset('images/avatar.jpeg') }}" alt="Norbert Orzechowicz" class="w-12 h-12 rounded-full flex-shrink-0">
                    <div>
                        <p class="font-bold text-base text-white mb-1">Sponsor Norbert Orzechowicz on GitHub</p>
                        <p class="text-gray-400 text-sm leading-relaxed">Sponsoring me means sponsoring the entire Flow PHP project &mdash; every library, every component, every release.</p>
                    </div>
                </div>
                <div class="mt-4 text-center">
                    <span class="inline-flex items-center gap-1 bg-gray-800 hover:bg-gray-700 text-white text-sm font-medium py-2 px-6 rounded-lg transition-colors">
                        <svg aria-hidden="true" height="16" viewBox="0 0 16 16" width="16" fill="#db61a2"><path d="m8 14.25.345.666a.75.75 0 0 1-.69 0l-.008-.004-.018-.01a7.152 7.152 0 0 1-.31-.17 22.055 22.055 0 0 1-3.434-2.414C2.045 10.731 0 8.35 0 5.5 0 2.836 2.086 1 4.25 1 5.797 1 7.153 1.802 8 3.02 8.847 1.802 10.203 1 11.75 1 13.914 1 16 2.836 16 5.5c0 2.85-2.045 5.231-3.885 6.818a22.066 22.066 0 0 1-3.744 2.584l-.018.01-.006.003h-.002Z"/></svg>
                        Sponsor
                    </span>
                </div>
            </a>
        </div>

        <hr class="my-4" />

        <div class="text-center">
            <h2 class="text-lg font-bold inline-block mb-2">Join Flow PHP Community!</h2>
            <iframe class="w-full mx-auto" src="https://discord.com/widget?id=1263821077558333451&theme=dark" height="350" allowtransparency="true" frameborder="0" sandbox="allow-popups allow-popups-to-escape-sandbox allow-same-origin allow-scripts"></iframe>
        </div>
    </div>
</div>
{% endblock %}
